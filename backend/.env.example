# Copy to .env and set your values
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PORT=8787
REQUEST_TIMEOUT_SECONDS=20
MAX_MESSAGE_CHARS=300
MAX_PROMPT_CHARS=12000
MAX_REQUEST_BYTES=65536
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
REQUIRED_X_REQUESTED_WITH=EatWiseChatClient
# Add ,null only if you intentionally open index.html via file://
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500
